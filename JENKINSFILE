pipeline {
    agent any

    stages {

        stage('Get Code') {
            steps {
                echo "===== STAGE 1: GET CODE ====="
                git branch: 'master',
                    url: 'https://github.com/Farithcarrillo/unir-cp-1-2'
                bat 'dir'
            }
        }

        stage('Unit') {
            steps {
                echo "===== STAGE 2: UNIT ====="
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '''
                        set PYTHONPATH=%WORKSPACE%
                        coverage run --branch --source=app --omit=app\\__init__.py,app\\api.py -m pytest --junitxml=result-unit.xml test\\unit
                    '''
                }
            }
            post {
                always {
                    junit 'result-unit.xml'
                }
            }
        }

        stage('Rest') {
            steps {
                echo "===== STAGE 3: REST ====="
                bat '''
                    REM Limpiar puertos por si quedaron procesos de runs anteriores
                    for /f "tokens=5" %%a in ('netstat -ano ^| findstr :5000 ^| findstr LISTENING') do taskkill /F /PID %%a 2>nul
                    for /f "tokens=5" %%a in ('netstat -ano ^| findstr :9090 ^| findstr LISTENING') do taskkill /F /PID %%a 2>nul
                    REM Levantar Flask y Wiremock en background
                    set FLASK_APP=app\\api.py
                    set FLASK_ENV=development
                    start flask run
                    start java -jar C:\\UNIR\\CP1-2\\wiremock-standalone-4.0.0-beta.34.jar --port 9090 --root-dir test\\wiremock
                    REM Esperar a que ambos respondan (max 30s cada uno)
                    powershell -Command "$ok=$false; for($i=0; $i -lt 30; $i++) { try { (New-Object Net.Sockets.TcpClient('127.0.0.1',5000)).Close(); $ok=$true; break } catch { Start-Sleep -Seconds 1 } }; if(-not $ok){ exit 1 }"
                    powershell -Command "$ok=$false; for($i=0; $i -lt 30; $i++) { try { (New-Object Net.Sockets.TcpClient('127.0.0.1',9090)).Close(); $ok=$true; break } catch { Start-Sleep -Seconds 1 } }; if(-not $ok){ exit 1 }"
                '''
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '''
                        set PYTHONPATH=%WORKSPACE%
                        pytest --junitxml=result-rest.xml test\\rest
                    '''
                }
            }
            post {
                always {
                    junit 'result-rest.xml'
                    bat '''
                        for /f "tokens=5" %%a in ('netstat -ano ^| findstr :5000 ^| findstr LISTENING') do taskkill /F /PID %%a 2>nul
                        for /f "tokens=5" %%a in ('netstat -ano ^| findstr :9090 ^| findstr LISTENING') do taskkill /F /PID %%a 2>nul
                        exit /b 0
                    '''
                }
            }
        }

        stage('Static') {
            steps {
                echo "===== STAGE 4: STATIC (flake8) ====="
                bat 'flake8 --format=pylint --exit-zero --output-file=flake8.out app'
                recordIssues(
                    tools: [flake8(name: 'Flake8', pattern: 'flake8.out')],
                    qualityGates: [
                        [threshold: 8,  type: 'TOTAL', unstable: true],
                        [threshold: 10, type: 'TOTAL', unstable: false]
                    ]
                )
            }
        }

        stage('Security') {
            steps {
                echo "===== STAGE 5: SECURITY (bandit) ====="
                bat '''
                    bandit -r . -f custom -o bandit.out --msg-template "{abspath}:{line}: {severity}: {test_id}: {msg}"
                    exit /b 0
                '''
                recordIssues(
                    tools: [pyLint(name: 'Bandit', pattern: 'bandit.out')],
                    qualityGates: [
                        [threshold: 2, type: 'TOTAL', unstable: true],
                        [threshold: 4, type: 'TOTAL', unstable: false]
                    ]
                )
            }
        }

        stage('Performance') {
            steps {
                echo "===== STAGE 6: PERFORMANCE (JMeter) ====="
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '''
                        if exist flask.jtl del flask.jtl
                        REM Limpiar puerto 5000
                        for /f "tokens=5" %%a in ('netstat -ano ^| findstr :5000 ^| findstr LISTENING') do taskkill /F /PID %%a 2>nul
                        REM Levantar Flask
                        set FLASK_APP=app\\api.py
                        set FLASK_ENV=development
                        start flask run
                        REM Esperar a que Flask responda
                        powershell -Command "$ok=$false; for($i=0; $i -lt 30; $i++) { try { (New-Object Net.Sockets.TcpClient('127.0.0.1',5000)).Close(); $ok=$true; break } catch { Start-Sleep -Seconds 1 } }; if(-not $ok){ exit 1 }"
                        REM Ejecutar JMeter
                        C:\\UNIR\\CP1-2\\apache-jmeter-5.6.3\\bin\\jmeter -n -t test\\jmeter\\flask.jmx -f -l flask.jtl
                    '''
                    perfReport sourceDataFiles: 'flask.jtl'
                }
            }
            post {
                always {
                    bat '''
                        for /f "tokens=5" %%a in ('netstat -ano ^| findstr :5000 ^| findstr LISTENING') do taskkill /F /PID %%a 2>nul
                        exit /b 0
                    '''
                }
            }
        }

        stage('Coverage') {
            steps {
                echo "===== STAGE 7: COVERAGE ====="
                bat '''
                    coverage xml -o coverage.xml
                '''
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    recordCoverage(
                        tools: [[parser: 'COBERTURA', pattern: 'coverage.xml']],
                        qualityGates: [
                            [threshold: 95.0, metric: 'LINE',   baseline: 'PROJECT', criticality: 'NOTE'],
                            [threshold: 85.0, metric: 'LINE',   baseline: 'PROJECT', criticality: 'UNSTABLE'],
                            [threshold: 90.0, metric: 'BRANCH', baseline: 'PROJECT', criticality: 'NOTE'],
                            [threshold: 80.0, metric: 'BRANCH', baseline: 'PROJECT', criticality: 'UNSTABLE']
                        ]
                    )
                }
            }
        }
    }
}
